#!/bin/bash
set -euo pipefail

# ingest — Containerized document ingestion CLI for Claude Code RAG.
#
# Usage:
#   ./rag/ingest add <file> --title "Title" --topic "subject"
#   ./rag/ingest list
#   ./rag/ingest delete --title "Title"
#
# The first run builds the image and downloads the embedding model (~270MB).

IMAGE="claude-rag-ingest"
CACHE_VOLUME="claude-rag-cache"

# Build image if it doesn't exist
if ! podman image exists "$IMAGE" 2>/dev/null; then
  echo "[rag] Building container image (first time only)..."
  podman build -t "$IMAGE" -f "$(dirname "$0")/Containerfile" "$(dirname "$0")"
fi

# Ensure model cache volume exists
podman volume exists "$CACHE_VOLUME" 2>/dev/null || podman volume create "$CACHE_VOLUME" >/dev/null

# On macOS, Podman containers run in a Linux VM. "localhost" inside the
# container reaches the VM, not the Mac. Ollama runs on the Mac, so we
# use host.containers.internal to reach it. Qdrant also runs in Podman
# so localhost works for it via port mapping on the VM.
OLLAMA_HOST="${OLLAMA_URL:-http://host.containers.internal:11434}"

# Base podman run args:
#   --rm         : clean up after run
#   --network host : access Qdrant (6333) on the VM's localhost
#   -v cache     : persist embedding model downloads across runs
#   -e OLLAMA_URL: route to host's Ollama via podman gateway
RUN_ARGS=(
  --rm
  --network host
  -v "${CACHE_VOLUME}:/root/.cache"
  -e "OLLAMA_URL=${OLLAMA_HOST}"
)

# Filter noisy C++ runtime warnings from stderr while preserving tqdm output.
# onnxruntime cpuid/GPU warnings fire at library load before any Python runs.
run_filtered() {
  podman run "${RUN_ARGS[@]}" "$IMAGE" "$@" \
    2> >(grep -v -E "onnxruntime cpuid|device_discovery|unauthenticated requests" >&2)
  return "${PIPESTATUS[0]:-$?}"
}

# If first arg is "add", mount the document file into the container
if [ "${1:-}" = "add" ] && [ -n "${2:-}" ]; then
  FILE="$(cd "$(dirname "$2")" && pwd)/$(basename "$2")"
  if [ ! -f "$FILE" ]; then
    echo "Error: $FILE not found" >&2
    exit 1
  fi
  MOUNT_DIR="$(dirname "$FILE")"
  FILENAME="$(basename "$FILE")"
  RUN_ARGS+=(-v "$MOUNT_DIR:/data:ro")
  shift 2
  run_filtered add "/data/$FILENAME" "$@"
else
  run_filtered "$@"
fi
